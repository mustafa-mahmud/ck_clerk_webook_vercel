{
	"type": "module",
	"dependencies": {
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"mongoose": "^9.6.2",
		"svix": "^1.93.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/mongoose": "^5.11.96",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"dev": "nodemon",
		"start": "node dist/server.js"
	},
	"nodemonConfig": {
		"watch": [
			"."
		],
		"ext": "ts,tsx,js,json",
		"ignore": [
			"node_modules",
			"dist"
		],
		"exec": "node --loader ts-node/esm server.ts"
	}
}